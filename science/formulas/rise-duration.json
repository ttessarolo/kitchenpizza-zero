{
  "type": "factor_chain",
  "id": "rise_duration",
  "ref": "[C] Cap. 44",
  "_meta": {
    "section": "rise",
    "displayName": "meta.factor_chain.rise_duration.name",
    "description": "meta.factor_chain.rise_duration.desc",
    "tags": ["rise", "duration", "fermentation", "casucci", "factor-chain"],
    "lastModified": "2026-03-27",
    "author": "system"
  },
  "base": { "value": 60, "unit": "min" },
  "factors": [
    {
      "id": "method_tf",
      "ref": "Rise method time factor (room=1, fridge=3.6, ctrl18=1.4, ctrl12=2.2)",
      "source": "lookup",
      "table": "rise_methods",
      "key": "$method",
      "field": "tf"
    },
    {
      "id": "yeast_inverse",
      "ref": "Inverse yeast proportion — less yeast = longer rise",
      "expr": ["Divide", 2, ["Max", "yeastPct", 0.5]],
      "latex": "\\frac{2}{\\max(yeastPct, 0.5)}"
    },
    {
      "id": "W_factor",
      "ref": "Flour strength normalization to W280 reference",
      "expr": ["Divide", 280, ["Max", "W", 50]],
      "latex": "\\frac{280}{\\max(W, 50)}"
    },
    {
      "id": "starch_damage",
      "ref": "Higher starch damage = slightly faster fermentation",
      "expr": ["Subtract", 1, ["Multiply", ["Subtract", "starchDamage", 7], 0.02]],
      "latex": "1 - ((starchDamage - 7) \\cdot 0.02)"
    },
    {
      "id": "falling_number",
      "ref": "Lower FN = more amylase = faster rise. Reference FN=300, min 150",
      "expr": ["Divide", 300, ["Max", "fallingNumber", 150]],
      "latex": "\\frac{300}{\\max(fallingNumber, 150)}"
    },
    {
      "id": "fiber",
      "ref": "High fiber slows gluten development. Reference fiber=3%",
      "expr": ["Add", 1, ["Max", 0, ["Multiply", ["Subtract", "fiber", 3], 0.02]]],
      "latex": "1 + \\max(0, (fiber - 3) \\cdot 0.02)"
    },
    {
      "id": "yeast_speed",
      "ref": "Yeast speed factor: fresh=1, madre=0.25-0.3",
      "expr": ["Divide", 1, ["Max", "yeastSpeedFactor", 0.1]],
      "latex": "\\frac{1}{\\max(yeastSpeedFactor, 0.1)}"
    },
    {
      "id": "temp_factor",
      "ref": "Temperature factor from Q10 model",
      "source": "input",
      "key": "temperatureFactor"
    },
    {
      "id": "salt_inhibition",
      "ref": "[C] Cap. 53 — Salt above 2.5% inhibits yeast",
      "expr": ["Add", 1, ["Max", 0, ["Multiply", ["Subtract", "saltPct", 2.5], 0.1]]],
      "latex": "1 + \\max(0, (saltPct - 2.5) \\cdot 0.1)"
    },
    {
      "id": "sugar_inhibition",
      "ref": "Sugar above 5% inhibits yeast (osmotic stress)",
      "expr": ["Add", 1, ["Max", 0, ["Multiply", ["Subtract", "sugarPct", 5], 0.05]]],
      "latex": "1 + \\max(0, (sugarPct - 5) \\cdot 0.05)"
    },
    {
      "id": "fat_inhibition",
      "ref": "Fat above 3% slows fermentation slightly",
      "expr": ["Add", 1, ["Max", 0, ["Multiply", ["Subtract", "fatPct", 3], 0.02]]],
      "latex": "1 + \\max(0, (fatPct - 3) \\cdot 0.02)"
    }
  ],
  "output": { "name": "durationMin", "unit": "min", "round": 0, "min": 15 }
}
