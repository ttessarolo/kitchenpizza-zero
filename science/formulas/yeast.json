{
  "type": "formula",
  "id": "yeast_pct",
  "ref": "[C] Cap. 44 — Formula L",
  "_meta": {
    "section": "dough",
    "displayName": "meta.formula.yeast_pct.name",
    "description": "meta.formula.yeast_pct.desc",
    "tags": ["yeast", "casucci", "formula-l", "fermentation"],
    "lastModified": "2026-03-27",
    "author": "system"
  },
  "variants": [
    {
      "key": "formula_l",
      "nameKey": "variant.yeast.formula_l",
      "descriptionKey": "variant.yeast.formula_l.desc",
      "expr": ["Divide", "K", ["Multiply", "hydration", ["Multiply", ["Power", "tempC", 2], "hours"]]],
      "latex": "\\frac{K}{hydration \\cdot T_{C}^{2} \\cdot hours}",
      "constants": { "K": 100000 },
      "applicability": { "minHours": 1, "maxHours": 48, "minTemp": 18, "maxTemp": 30 },
      "default": true
    },
    {
      "key": "q10_model",
      "nameKey": "variant.yeast.q10",
      "descriptionKey": "variant.yeast.q10.desc",
      "expr": ["Divide", ["Multiply", "baseYeast", ["Power", "Q10", ["Divide", ["Subtract", "Tref", "tempC"], 10]]], "hours"],
      "latex": "\\frac{baseYeast \\cdot Q10^{\\frac{T_{ref} - T_{C}}{10}}}{hours}",
      "constants": { "baseYeast": 1.5, "Q10": 2, "Tref": 24 },
      "applicability": { "minHours": 24, "maxHours": 98, "minTemp": 2, "maxTemp": 45 }
    }
  ],
  "inputs": ["hours", "tempC", "hydration"],
  "output": { "name": "yeastPct", "unit": "%", "round": 3 },
  "validation": {
    "hours": { "min": 0.1, "max": 98 },
    "tempC": { "min": 1, "max": 45 }
  }
}
