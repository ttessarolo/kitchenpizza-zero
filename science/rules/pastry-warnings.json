[
  {
    "type": "rule",
    "id": "pastry_temper_dark_too_hot",
    "_meta": { "section": "pastry", "displayName": "meta.rule.pastry_temper_dark_too_hot.name", "description": "meta.rule.pastry_temper_dark_too_hot.desc", "tags": ["pastry", "tempering", "chocolate", "dark", "error"], "lastModified": "2026-03-29", "author": "system" },
    "category": "pastry",
    "severity": "error",
    "messageKey": "warning.pastry_temper_dark_too_hot",
    "messageVars": ["workTemp", "chocolateType"],
    "conditions": [
      { "field": "workTemp", "op": "gt", "value": 32 },
      { "field": "chocolateType", "op": "eq", "value": "dark" }
    ],
    "actions": [
      {
        "labelKey": "action.lower_work_temp",
        "mutations": [{ "type": "updateNode", "patch": { "workTemp": 31 } }]
      }
    ]
  },
  {
