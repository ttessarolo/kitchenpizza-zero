{
  "expo": {
    "name": "KitchenPizza",
    "slug": "kitchenpizza",
    "version": "0.0.0",
    "orientation": "portrait",
    "scheme": "kitchenpizza",
    "platforms": ["ios", "android"],
    "ios": {
      "bundleIdentifier": "com.kitchenpizza.app",
      "supportsTablet": true
    },
    "android": {
      "package": "com.kitchenpizza.app",
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "@sentry/react-native/expo",
        {
          "organization": "radiozero",
          "project": "kitchenpizza"
        }
      ]
    ]
  }
}
