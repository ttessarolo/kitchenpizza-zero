CLERK_SECRET_KEY=sk_...
CLERK_SIGN_IN_URL=/sign-in
CLERK_WEBHOOK_SIGNING_SECRET=whsec_...
VITE_IMAGE_PREFIX_PATH=https://...
ABLY_API_KEY=...
SENTRY_AUTH_TOKEN=...
VITE_SENTRY_DSN=https://...
MY_AWS_ACCESS_KEY_ID=...
MY_AWS_SECRET_ACCESS_KEY=...
MY_AWS_REGION=eu-west-1
S3_BUCKET_NAME=...
