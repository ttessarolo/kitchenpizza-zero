# CookingScienceBrain DB (separate Neon project)
NEON_CSB_DATABASE_URL=postgresql://...@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require

# Graph Engine V2
USE_V2_RECONCILER=false

# Brain 3 — LLM (OpenAI)
LLM_ENABLED=true
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-5.4-mini
LLM_MAX_TOKENS=4096
LLM_TIMEOUT_MS=30000

